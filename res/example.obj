# Простой куб в формате OBJ
# Вертексы (позиции)
v -0.5 -0.5 1.0
v 0.5 -0.5 1.0
v 0.5 0.5 1.0
v -0.5 0.5 1.0
v 1.0 -1.0 -1.0
v -1.0 -1.0 -1.0
v -1.0 1.0 -1.0
v 1.0 1.0 -1.0

# Текстурные координаты
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0

# Грани (индексы вертексов/текстур)
# Передняя грань
f 1/1 2/2 3/3
f 3/3 4/4 1/1

# Задняя грань
f 5/1 6/2 7/3
f 7/3 8/4 5/1

# Левая грань
f 6/1 1/2 4/3
f 4/3 7/4 6/1

# Правая грань
f 2/1 5/2 8/3
f 8/3 3/4 2/1

# Верхняя грань
f 4/1 3/2 8/3
f 8/3 7/4 4/1

# Нижняя грань
f 6/1 5/2 2/3
f 2/3 1/4 6/1
